# Copy to .env and fill in values. Never commit .env.

# Supabase (Keychain: supabase-url, supabase-anon-key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (Keychain: mapbox-access-token)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Places API (Keychain: google-places-api-key) — server-side only
GOOGLE_PLACES_API_KEY=

# Admin auth (Keychain: recs-admin-password)
ADMIN_PASSWORD=

# Vercel Cron secret (auto-generated, set in Vercel dashboard)
CRON_SECRET=
